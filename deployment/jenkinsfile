pipeline {
    agent any
    environment {
        BLUE_DIR = '/var/www/hackathon-blue'
        GREEN_DIR = '/var/www/hackathon-green'
        ACTIVE_LINK = '/var/www/hackathon'
        SERVICE_NAME = 'hackathon'
        PATH = "/root/.local/bin:${env.PATH}"
    }
    stages {
        stage('Build') {
            steps {
                sh 'uv sync'
            }
        }
        stage('Test') {
            steps {
                sh 'uv run pytest --cov=app --cov-fail-under=70'
            }
        }
        stage('Deploy to Staging') {
            steps {
                sh '''
                    LIVE=$(readlink $ACTIVE_LINK)
                    if [ "$LIVE" = "$BLUE_DIR" ]; then
                        DEPLOY_DIR=$GREEN_DIR
                    else
                        DEPLOY_DIR=$BLUE_DIR
                    fi

                    rsync -av --exclude='.git' --exclude='.venv' . $DEPLOY_DIR
                    cd $DEPLOY_DIR && PYTHONPATH=. uv run python scripts/db_setup.py

                    # Launch Staging Clone Army directly encapsulated on port 5001 seamlessly
                    cd $DEPLOY_DIR
                    export PROXY_PORT=5001
                    export COMPOSE_PROJECT_NAME=hackathon-staging
                    docker compose down 2>/dev/null || true
                    docker compose up -d --build
                '''
            }
        }
        stage('Health Check Staging') {
            steps {
                sh '''
                    sleep 5
                    curl -f http://localhost:5001/health || exit 1
                '''
            }
        }
        stage('Switch Traffic') {
            steps {
                sh '''
                    LIVE=$(readlink $ACTIVE_LINK)
                    if [ "$LIVE" = "$BLUE_DIR" ]; then
                        DEPLOY_DIR=$GREEN_DIR
                        OLD_DIR=$BLUE_DIR
                    else
                        DEPLOY_DIR=$BLUE_DIR
                        OLD_DIR=$GREEN_DIR
                    fi

                    ln -sfn $DEPLOY_DIR $ACTIVE_LINK

                    # Boot up the Live Production Horde cleanly routed directly at port 5000!
                    cd $DEPLOY_DIR
                    export PROXY_PORT=5000
                    export COMPOSE_PROJECT_NAME=hackathon-prod
                    docker compose down 2>/dev/null || true
                    docker compose up -d

                    # Natively tear down the previous staging setup cleanly isolating RAM usages
                    export COMPOSE_PROJECT_NAME=hackathon-staging
                    docker compose down 2>/dev/null || true

                    # Terminate the outdated Production Clone Army to zero-downtime seamlessly switch over!
                    cd $OLD_DIR || true
                    export COMPOSE_PROJECT_NAME=hackathon-prod
                    docker compose down 2>/dev/null || true
                '''
            }
        }
        stage('Health Check Production') {
            steps {
                sh '''
                    sleep 5
                    curl -f http://localhost/health || exit 1
                '''
            }
        }
    }
    post {
        failure {
            echo 'Pipeline failed — production untouched, stopping staging...'
            sh 'export COMPOSE_PROJECT_NAME=hackathon-staging && docker compose down 2>/dev/null || true'
        }
        success {
            echo 'Deployment successful!'
        }
    }
}