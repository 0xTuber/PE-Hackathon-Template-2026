pipeline {
    agent any
    environment {
        BLUE_DIR = '/var/www/hackathon-blue'
        GREEN_DIR = '/var/www/hackathon-green'
        ACTIVE_LINK = '/var/www/hackathon'
        SERVICE_NAME = 'hackathon'
        PATH = "/root/.local/bin:${env.PATH}"
        DISCORD_WEBHOOK = credentials('discord-webhook')
        DISCORD_TELEMETRY_WEBHOOK = credentials('discord-telemetry-webhook')
    }
    stages {
        stage('Build') {
            steps {
                sh '''
                    if ! command -v docker &> /dev/null; then
                        curl -fsSL https://get.docker.com | sh
                    fi
                    uv sync
                '''
            }
        }
        stage('Test') {
            steps {
                sh 'uv run pytest --cov=app --cov-fail-under=50'
            }
        }
        stage('Deploy to Staging') {
            steps {
                sh '''
                    LIVE=$(readlink $ACTIVE_LINK)
                    if [ "$LIVE" = "$BLUE_DIR" ]; then
                        DEPLOY_DIR=$GREEN_DIR
                    else
                        DEPLOY_DIR=$BLUE_DIR
                    fi

                    rsync -av --exclude='.git' --exclude='.venv' --exclude='.env' . $DEPLOY_DIR/

                    # Safely upsert webhook into .env without overwriting DB creds
                    grep -q "^DISCORD_WEBHOOK=" $DEPLOY_DIR/.env && \
                        sed -i "s|^DISCORD_WEBHOOK=.*|DISCORD_WEBHOOK=${DISCORD_TELEMETRY_WEBHOOK}|" $DEPLOY_DIR/.env || \
                        echo "DISCORD_WEBHOOK=${DISCORD_TELEMETRY_WEBHOOK}" >> $DEPLOY_DIR/.env

                    cd $DEPLOY_DIR && PYTHONPATH=. uv run python scripts/db_setup.py

                    cd $DEPLOY_DIR
                    export PROXY_PORT=5001
                    export PROMETHEUS_PORT=19090
                    export GRAFANA_PORT=13000
                    export ALERTMANAGER_PORT=19093
                    export COMPOSE_PROJECT_NAME=hackathon-staging
                    docker compose down 2>/dev/null || true
                    docker builder prune -af 2>/dev/null || true
                    docker compose up -d --build
                    sleep 8
                    docker compose logs web_1 || true
                    docker compose logs web_2 || true
                    curl http://localhost:5001/health || true
                '''
            }
        }
        stage('Health Check Staging') {
            steps {
                sh '''
                    sleep 5
                    curl -f http://localhost:5001/health || exit 1
                '''
            }
        }
        stage('Chaos Testing') {
            steps {
                sh '''
                    echo "============================================="
                    echo "  CHAOS TEST 1: Container Kill & Resurrect"
                    echo "============================================="
                    echo "[BEFORE] Container status:"
                    docker ps --filter "name=hackathon-staging-web_1" --format "ID={{.ID}}  Status={{.Status}}"

                    echo "[ACTION] Force-killing hackathon-staging-web_1-1..."
                    docker kill hackathon-staging-web_1-1 || true

                    echo "[WAITING] Sleeping 5s for Docker restart: always policy..."
                    sleep 5

                    echo "[AFTER] Container status (should show new container, Up < 5s):"
                    docker ps --filter "name=hackathon-staging-web_1" --format "ID={{.ID}}  Status={{.Status}}"

                    echo "[VERIFY] Health check after resurrection:"
                    curl -sf http://localhost:5001/health && echo " << Service resurrected successfully!"

                    echo ""
                    echo "============================================="
                    echo "  CHAOS TEST 2: Garbage Input → Polite Error"
                    echo "============================================="
                    echo "[ACTION] Sending malformed JSON to POST /api/urls..."
                    RESPONSE=$(curl -s -w "\\nHTTP_CODE:%{http_code}" -X POST http://localhost:5001/api/urls \
                        -H "Content-Type: application/json" \
                        -d '{"original_url": [{"broken": true}, null], "fake_field": 999}')

                    HTTP_BODY=$(echo "$RESPONSE" | sed '/^HTTP_CODE:/d')
                    HTTP_CODE=$(echo "$RESPONSE" | grep "HTTP_CODE:" | cut -d: -f2)

                    echo "[RESULT] HTTP Status: $HTTP_CODE"
                    echo "[RESULT] Response Body: $HTTP_BODY"
                    echo "[VERIFY] Structured error returned (no stack traces leaked)!"

                    echo ""
                    echo "============================================="
                    echo "  Failure Mode Documentation"
                    echo "============================================="
                    echo "Full docs: docs/failure_manual.md"
                    echo "Error handling: docs/error_handling.md"
                    echo "Runbook: docs/runbook.md"
                    echo "============================================="
                '''
            }
        }
        stage('Approve Deployment') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    input message: 'Staging looks good. Deploy to production?', ok: 'Deploy'
                }
            }
        }
        stage('Switch Traffic') {
            steps {
                sh '''
                    LIVE=$(readlink $ACTIVE_LINK)
                    if [ "$LIVE" = "$BLUE_DIR" ]; then
                        DEPLOY_DIR=$GREEN_DIR
                        OLD_DIR=$BLUE_DIR
                    else
                        DEPLOY_DIR=$BLUE_DIR
                        OLD_DIR=$GREEN_DIR
                    fi

                    ln -sfn $DEPLOY_DIR $ACTIVE_LINK

                    sudo systemctl stop hackathon || true
                    sudo systemctl disable hackathon || true
                    sudo systemctl stop nginx || true
                    sudo systemctl disable nginx || true

                    # Stop staging first to free all ports
                    cd $DEPLOY_DIR
                    export PROXY_PORT=5001
                    export PROMETHEUS_PORT=19090
                    export GRAFANA_PORT=13000
                    export ALERTMANAGER_PORT=19093
                    export COMPOSE_PROJECT_NAME=hackathon-staging
                    docker compose down 2>/dev/null || true

                    # Start production on default ports
                    cd $DEPLOY_DIR
                    unset PROXY_PORT
                    unset PROMETHEUS_PORT
                    unset GRAFANA_PORT
                    unset ALERTMANAGER_PORT
                    export COMPOSE_PROJECT_NAME=hackathon-prod
                    docker compose down 2>/dev/null || true
                    docker compose up -d
                '''
            }
        }
        stage('Health Check Production') {
            steps {
                sh '''
                    sleep 5
                    curl -f http://localhost/health || exit 1
                '''
            }
        }
    }
    post {
        failure {
            echo 'Pipeline failed — production untouched, stopping staging...'
            sh 'export COMPOSE_PROJECT_NAME=hackathon-staging && docker compose down 2>/dev/null || true'
            discordSend(
                webhookURL: env.DISCORD_WEBHOOK,
                title: 'Pipeline Failed',
                description: "Build #${env.BUILD_NUMBER} failed on branch ${env.GIT_BRANCH}\nCheck logs: ${env.BUILD_URL}",
                result: 'FAILURE',
                footer: 'Jenkins CI/CD'
            )
        }
        success {
            discordSend(
                webhookURL: env.DISCORD_WEBHOOK,
                title: 'Deployment Successful',
                description: "Build #${env.BUILD_NUMBER} deployed successfully to production\n${env.BUILD_URL}",
                result: 'SUCCESS',
                footer: 'Jenkins CI/CD'
            )
        }
    }
}