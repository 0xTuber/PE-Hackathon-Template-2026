pipeline {
    agent any
    environment {
        BLUE_DIR = '/var/www/hackathon-blue'
        GREEN_DIR = '/var/www/hackathon-green'
        ACTIVE_LINK = '/var/www/hackathon'
        SERVICE_NAME = 'hackathon'
        PATH = "/root/.local/bin:${env.PATH}"
    }
    stages {
        stage('Build') {
            steps {
                sh 'uv sync'
            }
        }
        stage('Test') {
            steps {
                sh 'uv run pytest tests/test_users.py tests/test_urls.py tests/test_events.py'
            }
        }
        stage('Deploy to Staging') {
            steps {
                sh '''
                    LIVE=$(readlink $ACTIVE_LINK)
                    if [ "$LIVE" = "$BLUE_DIR" ]; then
                        DEPLOY_DIR=$GREEN_DIR
                    else
                        DEPLOY_DIR=$BLUE_DIR
                    fi

                    rsync -av --exclude='.git' --exclude='.venv' . $DEPLOY_DIR
                    cd $DEPLOY_DIR && uv run python scripts/db_setup.py

                    sudo bash -c "cat > /etc/systemd/system/hackathon-staging.service << EOF
[Unit]
Description=Hackathon Flask App (Staging)
After=network.target

[Service]
User=root
WorkingDirectory=$DEPLOY_DIR
Environment=PATH=/root/.local/bin:/usr/local/bin:/usr/bin
ExecStart=/root/.local/bin/uv run gunicorn -w 4 -b 0.0.0.0:5001 app:app
Restart=always

[Install]
WantedBy=multi-user.target
EOF"

                    sudo systemctl daemon-reload
                    sudo systemctl restart hackathon-staging
                '''
            }
        }
        stage('Health Check Staging') {
            steps {
                sh '''
                    sleep 5
                    curl -f http://localhost:5001/health || exit 1
                '''
            }
        }
        stage('Switch Traffic') {
            steps {
                sh '''
                    LIVE=$(readlink $ACTIVE_LINK)
                    if [ "$LIVE" = "$BLUE_DIR" ]; then
                        DEPLOY_DIR=$GREEN_DIR
                    else
                        DEPLOY_DIR=$BLUE_DIR
                    fi

                    ln -sfn $DEPLOY_DIR $ACTIVE_LINK

                    sudo bash -c "cat > /etc/systemd/system/hackathon.service << EOF
[Unit]
Description=Hackathon Flask App
After=network.target

[Service]
User=root
WorkingDirectory=$DEPLOY_DIR
Environment=PATH=/root/.local/bin:/usr/local/bin:/usr/bin
ExecStart=/root/.local/bin/uv run gunicorn -w 4 -b 0.0.0.0:5000 app:app
Restart=always

[Install]
WantedBy=multi-user.target
EOF"

                    sudo systemctl daemon-reload
                    sudo systemctl enable $SERVICE_NAME
                    sudo systemctl restart $SERVICE_NAME
                    sudo systemctl stop hackathon-staging
                '''
            }
        }
        stage('Health Check Production') {
            steps {
                sh '''
                    sleep 5
                    curl -f http://localhost/health || exit 1
                '''
            }
        }
    }
    post {
        failure {
            echo 'Pipeline failed — production untouched, stopping staging...'
            sh 'sudo systemctl stop hackathon-staging || true'
        }
        success {
            echo 'Deployment successful!'
        }
    }
}